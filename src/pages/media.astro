---
import BaseLayout from "../layouts/BaseLayout.astro";
import YouTube from "../components/YouTube.astro";
import Bandcamp from "../components/Bandcamp.astro";
import media from "../content/media.json";
import { withBase } from "../utils/paths";

const audios = Array.isArray(media.audios) ? media.audios : [];
const lives = Array.isArray(media.lives) ? media.lives : [];
const compos = Array.isArray(media.compos) ? media.compos : [];
const repets = Array.isArray(media.repets) ? media.repets : [];

function normalize(list) {
  return list.map((v) => {
    if (v?.provider === "file" || v?.provider === "local") {
      const raw = String(v.src || "").trim();
      const src = withBase(raw.replace(/^\//, ""));
      const poster = v.poster ? withBase(String(v.poster).replace(/^\//, "")) : undefined;
      return { ...v, src, poster };
    }
    return v;
  });
}

const normAudios = audios.map((a) => {
  if (a?.provider === "file" || a?.provider === "local") {
    const raw = String(a.src || "").trim();
    return { ...a, src: withBase(raw.replace(/^\//, "")) };
  }
  return a;
});

const normLives = normalize(lives);
const normCompos = normalize(compos);
const normRepets = normalize(repets);

function metaLine(item) {
  const parts = [];
  if (item.kind) parts.push(String(item.kind));
  if (item.location) parts.push(String(item.location));
  if (item.year) parts.push(String(item.year));
  return parts.join(" • ");
}

function sectionDescription(id) {
  if (id === "audios") {
    return "Écoute l’EP de Nevrosyne et plonge dans l’univers du groupe entre compos, énergie rock et identité bien à part.";
  }
  if (id === "lives") {
    return "Retrouve Nevrosyne sur scène : festivals, salles, soirées privées et lives.";
  }
  if (id === "compos") {
    return "Découvre les compos originales de Nevrosyne : du rock, de l’énergie et une petite dose de névrose maison.";
  }
  if (id === "repets") {
    return "Quelques extraits de répétes pour voir ce qui se passe avant de monter sur scène. Spoiler : ça travaille, mais pas toujours dans le calme.";
  }
  return "";
}

const allVideos = [...normLives, ...normCompos, ...normRepets].filter((v) => v?.provider === "youtube" && v?.id);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MusicGroup",
      name: "Nevrosyne",
      url: "https://nevrosyne-web.github.io/nevrosyne-site/media",
      genre: "Rock",
      description:
        "Nevrosyne est un groupe de rock basé en Provence, disponible pour concerts, mariages et événements privés."
    },
    {
      "@type": "CollectionPage",
      name: "Médias — Nevrosyne",
      url: "https://nevrosyne-web.github.io/nevrosyne-site/media",
      description:
        "Vidéos live, compositions, répétitions et extraits audio du groupe de rock Nevrosyne en Provence."
    },
    ...allVideos.map((v) => ({
      "@type": "VideoObject",
      name: v.title,
      description: v.description || v.title,
      uploadDate: v.year ? `${v.year}-01-01` : undefined,
      contentUrl: `https://www.youtube.com/watch?v=${v.id}`,
      embedUrl: `https://www.youtube.com/embed/${v.id}`,
      thumbnailUrl: `https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`
    }))
  ]
};
---

<BaseLayout title="Médias — Nevrosyne">
  <Fragment slot="head">
    <meta
      name="description"
      content="Découvre les vidéos live, compositions et répétitions de Nevrosyne, groupe de rock basé en Provence, pour concerts, mariages et événements privés."
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="mb-12 space-y-4">
    <h1 class="text-3xl font-bold">Médias</h1>
    <p class="text-zinc-300 leading-relaxed">
      Retrouve ici les vidéos live, compos et extraits de répétitions de Nevrosyne.
      Du live, du son, un peu de sueur et parfois une légère perte de contrôle.
    </p>
    <p class="text-zinc-400 leading-relaxed">
      Basé en Provence, le groupe joue en concert, en festival, en mariage et lors d’événements privés
      à Aix-en-Provence, Marseille, Gardanne, Trets, Allauch et dans les environs.
      Cette page te permet de plonger dans l’univers du groupe, son énergie sur scène et son répertoire.
    </p>
  </section>

  <!-- {normAudios.length > 0 && (
    <section class="space-y-5 mb-14" id="audios">
      <div class="space-y-2">
        <h2 class="text-2xl font-semibold">À écouter</h2>
        <p class="text-zinc-400">
          {sectionDescription("audios")}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {normAudios.map((a) => (
          <article class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 space-y-4">
            <header class="space-y-2">
              <h3 class="text-lg font-semibold leading-snug">{a.title}</h3>
              {a.description && (
                <p class="text-sm text-zinc-300 leading-relaxed">{a.description}</p>
              )}
              {metaLine(a) && (
                <p class="text-xs uppercase tracking-wide text-zinc-500">{metaLine(a)}</p>
              )}
            </header>

            {a.provider === "bandcamp" ? (
              <Bandcamp embedUrl={a.embedUrl} title={a.title} />
            ) : a.provider === "file" || a.provider === "local" ? (
              <audio controls preload="metadata" class="w-full rounded-xl border border-zinc-800">
                <source src={a.src} type={a.mime || "audio/mpeg"} />
                Votre navigateur ne supporte pas l’audio.
              </audio>
            ) : null}
          </article>
        ))}
      </div>
    </section>
  )} -->

  {normLives.length > 0 && (
    <section class="space-y-5 mb-14" id="lives">
      <div class="space-y-2">
        <h2 class="text-2xl font-semibold">Nevro Lives</h2>
        <p class="text-zinc-400">
          {sectionDescription("lives")}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {normLives.map((v) => (
          <article class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 space-y-4">
            <header class="space-y-2">
              <h3 class="text-lg font-semibold leading-snug">{v.title}</h3>
              {v.description && (
                <p class="text-sm text-zinc-300 leading-relaxed">{v.description}</p>
              )}
              {metaLine(v) && (
                <p class="text-xs uppercase tracking-wide text-zinc-500">{metaLine(v)}</p>
              )}
            </header>

            {v.provider === "youtube" ? (
              <YouTube id={v.id} title={v.title} />
            ) : v.provider === "file" || v.provider === "local" ? (
              <video
                controls
                preload="metadata"
                poster={v.poster}
                class="w-full rounded-xl border border-zinc-800"
              >
                <source src={v.src} type={v.mime || "video/mp4"} />
                Votre navigateur ne supporte pas la vidéo.
              </video>
            ) : null}
          </article>
        ))}
      </div>
    </section>
  )}

  {normCompos.length > 0 && (
    <section class="space-y-5 mb-14" id="compos">
      <div class="space-y-2">
        <h2 class="text-2xl font-semibold">Nevro Compos</h2>
        <p class="text-zinc-400">
          {sectionDescription("compos")}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {normCompos.map((v) => (
          <article class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 space-y-4">
            <header class="space-y-2">
              <h3 class="text-lg font-semibold leading-snug">{v.title}</h3>
              {v.description && (
                <p class="text-sm text-zinc-300 leading-relaxed">{v.description}</p>
              )}
              {metaLine(v) && (
                <p class="text-xs uppercase tracking-wide text-zinc-500">{metaLine(v)}</p>
              )}
            </header>

            {v.provider === "youtube" ? (
              <YouTube id={v.id} title={v.title} />
            ) : v.provider === "file" || v.provider === "local" ? (
              <video
                controls
                preload="metadata"
                poster={v.poster}
                class="w-full rounded-xl border border-zinc-800"
              >
                <source src={v.src} type={v.mime || "video/mp4"} />
                Votre navigateur ne supporte pas la vidéo.
              </video>
            ) : null}
          </article>
        ))}
      </div>
    </section>
  )}

  {normRepets.length > 0 && (
    <section class="space-y-5" id="repets">
      <div class="space-y-2">
        <h2 class="text-2xl font-semibold">Nevro Répéts</h2>
        <p class="text-zinc-400">
          {sectionDescription("repets")}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {normRepets.map((v) => (
          <article class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 space-y-4">
            <header class="space-y-2">
              <h3 class="text-lg font-semibold leading-snug">{v.title}</h3>
              {v.description && (
                <p class="text-sm text-zinc-300 leading-relaxed">{v.description}</p>
              )}
              {metaLine(v) && (
                <p class="text-xs uppercase tracking-wide text-zinc-500">{metaLine(v)}</p>
              )}
            </header>

            {v.provider === "youtube" ? (
              <YouTube id={v.id} title={v.title} />
            ) : v.provider === "file" || v.provider === "local" ? (
              <video
                controls
                preload="metadata"
                poster={v.poster}
                class="w-full rounded-xl border border-zinc-800"
              >
                <source src={v.src} type={v.mime || "video/mp4"} />
                Votre navigateur ne supporte pas la vidéo.
              </video>
            ) : null}
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>