---
const { id, title = "Clip" } = Astro.props;

const videoUrl = `https://www.youtube.com/watch?v=${id}`;
const embedUrl = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
const thumbnail = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const iframeTitle = `Lecture vidéo YouTube : ${title}`;
---

<div
  class="group relative aspect-video overflow-hidden rounded-xl border border-zinc-800 bg-zinc-950"
  data-youtube-player
  data-embed-url={embedUrl}
>
  <button
    type="button"
    class="relative h-full w-full cursor-pointer"
    aria-label={`Lire la vidéo : ${title}`}
  >
    <img
      src={thumbnail}
      alt={title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
    />

    <div class="absolute inset-0 bg-black/30 transition group-hover:bg-black/20"></div>

    <div class="absolute inset-0 flex items-center justify-center">
      <span
        class="flex h-16 w-16 items-center justify-center rounded-full bg-black/70 text-white shadow-lg transition group-hover:scale-105"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 24 24"
          class="ml-1 h-8 w-8 fill-current"
        >
          <path d="M8 5v14l11-7z"></path>
        </svg>
      </span>
    </div>

    <div class="absolute bottom-0 left-0 right-0 p-3 text-left">
      <p class="line-clamp-2 text-sm font-medium text-white drop-shadow">
        {title}
      </p>
    </div>
  </button>

  <noscript>
    <iframe
      class="h-full w-full"
      src={`https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1`}
      title={iframeTitle}
      loading="lazy"
      referrerpolicy="strict-origin-when-cross-origin"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </noscript>
</div>

<script>
  document.addEventListener("click", (event) => {
    const button = event.target.closest("[data-youtube-player] > button");
    if (!button) return;

    const wrapper = button.parentElement;
    if (!wrapper) return;

    const embedUrl = wrapper.getAttribute("data-embed-url");
    if (!embedUrl) return;

    const label = button.getAttribute("aria-label") || "Lecture vidéo YouTube";

    const iframe = document.createElement("iframe");
    iframe.className = "h-full w-full";
    iframe.src = embedUrl;
    iframe.title = label;
    iframe.loading = "eager";
    iframe.referrerPolicy = "strict-origin-when-cross-origin";
    iframe.allow =
      "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
    iframe.allowFullscreen = true;

    wrapper.innerHTML = "";
    wrapper.appendChild(iframe);
  });
</script>